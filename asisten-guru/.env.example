# Kunci API Anthropic — HANYA dipakai di sisi server (serverless function).
# Jangan pernah menaruh nilai ini di kode frontend atau variabel berawalan VITE_.
ANTHROPIC_API_KEY=

# (Opsional) Ganti model yang dipakai proxy. Default: claude-sonnet-4-6
# Untuk hemat biaya gunakan: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
