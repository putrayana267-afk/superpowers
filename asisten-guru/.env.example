# Kunci API Google Gemini — HANYA dipakai di sisi server (serverless function).
# Jangan pernah menaruh nilai ini di kode frontend atau variabel berawalan VITE_.
# Dapatkan di: https://aistudio.google.com/app/apikey

# Multi-key (opsional, untuk rotasi/fallback saat kuota penuh).
# Isi sebanyak yang Anda punya; yang kosong diabaikan.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Fallback: tetap didukung bila hanya punya satu key.
GEMINI_API_KEY=
