# Kunci API Google Gemini — HANYA dipakai di sisi server (serverless function).
# Jangan pernah menaruh nilai ini di kode frontend atau variabel berawalan VITE_.
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (Opsional) Ganti model yang dipakai proxy. Default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
